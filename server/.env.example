# ===== 伺服器 =====
PORT=3000

# ===== MongoDB =====
# 本機: mongodb://localhost:27017/panshi
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/panshi
MONGODB_URI=mongodb://localhost:27017/panshi

# ===== SMTP 郵件 (可選) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="磐石烤地瓜 <your_email@gmail.com>"
